generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectType {
  SOFTWARE
  HOME
  AUTO
  EVENT
  CUSTOM
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum IssueStatus {
  OPEN
  RESOLVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  MEMBER_ADDED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  TASK_STATUS_CHANGED
  ISSUE_CREATED
  ISSUE_RESOLVED
  PROJECT_DELETED
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  ownedProjects  Project[]       @relation("ProjectOwner")
  taskNotes      TaskNote[]      @relation("TaskNoteAuthor")
  notifications  Notification[]
  apiTokens      ApiToken[]      @relation("ApiTokenCreator")
}

model Project {
  id                  String               @id @default(cuid())
  name                String
  type                ProjectType
  description         String?
  status              ProjectStatus        @default(PLANNING)
  startDate           DateTime?
  endDate             DateTime?
  lessonsLearned      String?
  ownerId             String
  owner               User                 @relation("ProjectOwner", fields: [ownerId], references: [id])
  members             ProjectMember[]
  phases              Phase[]
  tasks               Task[]
  issues              Issue[]
  apiTokens           ApiToken[]
  sharePointConnection SharePointConnection?
  clonedFromId        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  projectName String?
  type        NotificationType
  message     String
  link        String?
  readAt      DateTime?
  createdAt   DateTime          @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model ApiToken {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  createdById String
  createdBy   User      @relation("ApiTokenCreator", fields: [createdById], references: [id])
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model SharePointConnection {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenantId     String
  clientId     String
  clientSecret String
  siteUrl      String
  listName     String
  lastSyncAt   DateTime?
  lastSyncError String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  role      MemberRole  @default(EDITOR)
  createdAt DateTime    @default(now())

  @@unique([projectId, userId])
}

model Phase {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  wbsCode   String
  order     Int
  tasks     Task[]
}

model Task {
  id             String     @id @default(cuid())
  projectId      String
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId        String
  phase          Phase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  parentTaskId   String?
  parentTask     Task?      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks       Task[]     @relation("TaskSubtasks")
  name           String
  wbsCode        String
  description    String?
  status         TaskStatus @default(BACKLOG)
  priority       TaskPriority @default(MEDIUM)
  isMilestone    Boolean    @default(false)
  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  percentComplete Int       @default(0)
  estimatedHours Float?
  assigneeId     String?
  assignee       User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  order          Int        @default(0)
  issues         Issue[]
  notes          TaskNote[]
  dependsOn      TaskDependency[] @relation("Successor")
  blocks         TaskDependency[] @relation("Predecessor")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model TaskNote {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TaskNoteAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskDependency {
  id               String   @id @default(cuid())
  taskId           String
  task             Task     @relation("Successor", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId  String
  dependsOnTask    Task     @relation("Predecessor", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([taskId, dependsOnTaskId])
}

model Issue {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?       @relation(fields: [taskId], references: [id])
  title       String
  description String?
  status      IssueStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
}

model TemplateProject {
  id          String          @id @default(cuid())
  name        String
  type        ProjectType
  description String?
  isBuiltin   Boolean         @default(false)
  phases      TemplatePhase[]
  createdAt   DateTime        @default(now())
}

model TemplatePhase {
  id                String            @id @default(cuid())
  templateProjectId String
  templateProject   TemplateProject   @relation(fields: [templateProjectId], references: [id], onDelete: Cascade)
  name              String
  wbsCode           String
  order             Int
  tasks             TemplateTask[]
}

model TemplateTask {
  id                    String        @id @default(cuid())
  templatePhaseId       String
  templatePhase         TemplatePhase @relation(fields: [templatePhaseId], references: [id], onDelete: Cascade)
  name                  String
  wbsCode               String
  isMilestone           Boolean       @default(false)
  relativeStartDay      Int           @default(0)
  relativeDurationDays  Int           @default(1)
  order                 Int
}
